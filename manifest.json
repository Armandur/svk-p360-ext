{
  "manifest_version": 3,
  "name": "360° Svenska kyrkan – Hjälptillägg",
  "version": "1.1",
  "description": "Automatiserar repetitiva åtgärder i 360° för Svenska kyrkan. Fungerar i Chrome och Edge.",
  "permissions": ["activeTab", "scripting", "tabs", "storage"],
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "dagboksblad-skriv-ut": {
      "suggested_key": { "default": "Alt+Shift+D" },
      "description": "Skriv ut dagboksblad för aktuellt ärende"
    },
    "redigera-egenskaper": {
      "suggested_key": { "default": "Alt+Shift+E" },
      "description": "Redigera ärendets egenskaper"
    },
    "växla-status": {
      "suggested_key": { "default": "Alt+Shift+S" },
      "description": "Växla ärendets status mellan Öppet och Avslutat"
    },
    "makulera": {
      "suggested_key": { "default": "Alt+Shift+M" },
      "description": "Makulera ärendet (sätt status till Makulerat)"
    },
    "spara-som-nytt": {
      "description": "Spara ärendet som nytt ärende"
    }
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://p360.svenskakyrkan.se/*"],
      "js": ["content.js"]
    },
    {
      "matches": ["https://p360.svenskakyrkan.se/*"],
      "js": [
        "page-utils.js",
        "page-dagboksblad.js",
        "page-status.js",
        "page-arende.js",
        "page.js"
      ],
      "world": "MAIN"
    }
  ]
}
